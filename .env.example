# ===========================================
# Cursor MCP 环境变量（项目根目录）
# ===========================================
# 复制此文件为 .env 并填写实际值
# 修改 .env 后运行一次 ./sync-mcp-from-env.sh，之后直接打开 Cursor 即可（无需每次 source .env）
#
# 应用运行时环境变量见 Web/.env.example

# GitHub MCP（创建 issue/PR、仓库操作）
GITHUB_PERSONAL_ACCESS_TOKEN=

# Context7 MCP（文档检索）
CONTEXT7_API_KEY=

# n8n MCP（工作流）
N8N_API_URL=http://localhost:56789
N8N_API_KEY=
