    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server"
      ]
    },
    "manim-server": {
      "command": "~/anaconda3/envs/manim-mcp/bin/python",
      "args": [
        "~/AI/MCPs/manim-mcp-server/src/manim_server.py"
      ],
      "env": {
        "MANIM_EXECUTABLE": "~/anaconda3/envs/manim-mcp/bin/manim"
      }
    },
    "mcp-obsidian": {
      "command": "uvx",
      "args": [
        "mcp-obsidian"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "e78488b66a039f3a2a8add2d60a499b4b24065cfa0c9e8a19eb93b8c4a57ae96",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    },
    "Context7": {
      "url": "https://mcp.context7.com/mcp",
