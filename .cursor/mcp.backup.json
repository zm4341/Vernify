      }
    },
    "Playwright": {
      "command": "npx -y @playwright/mcp@latest",
      "env": {},
      "args": []
    },
    "pencil": {
      "name": "pencil",
      "transport": "stdio",
      "command": "/Users/minzhang/.cursor/extensions/highagency.pencildev-0.6.24-universal/out/mcp-server-darwin-arm64",
      "args": [
