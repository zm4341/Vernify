# Caddy 开发环境配置
# Next.js 为主后端（前端 + BFF），Caddy 不代理 FastAPI；Next.js 内部直接与 FastAPI 通信。
#
# 路由结构：
#   /              → Next.js (前端 + API Routes，含 /api/v1/ai/*、/api/v1/latex/* 代理)
#   /auth/*        → Supabase Auth
#   /storage/*     → Supabase Storage
#   /rest/*        → Supabase REST API
#   /studio/*      → Supabase Studio

{
	# 禁用自动 HTTPS（开发环境）
	auto_https off
	auto_https disable_redirects
	
	# 禁用管理端点
	admin off
	
	# 日志
	log {
		output stdout
		format console
		level INFO
	}
}

# 统一入口 - localhost:38080
:38080 {
	# =========================================
	# Supabase 服务
	# =========================================
	# Auth 服务
	handle /auth/* {
		reverse_proxy supabase-kong:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	
	# Storage 服务
	handle /storage/* {
		reverse_proxy supabase-kong:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	
	# REST API (PostgREST)
	handle /rest/* {
		reverse_proxy supabase-kong:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	
	# MCP 服务 - Supabase MCP（供 Cursor 等 AI 工具连接）
	handle /mcp* {
		reverse_proxy supabase-kong:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Realtime 服务 (WebSocket) - Caddy 原生处理 WebSocket upgrade，无需手动转发 Upgrade/Connection
	handle /realtime/* {
		reverse_proxy supabase-kong:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			flush_interval -1
		}
	}
	
	# =========================================
	# Supabase Studio (管理界面)
	# =========================================
	handle /studio/* {
		uri strip_prefix /studio
		reverse_proxy supabase-studio:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	
	# =========================================
	# Next.js (前端 + API Routes) - 默认路由
	# 处理所有其他请求，包括 /api/* 路由
	# =========================================
	handle {
		reverse_proxy frontend:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}

			# Caddy 原生支持 WebSocket upgrade，无需 header_up Upgrade/Connection
			# 手动设置会将 {>Upgrade} 作为字面量发送，导致 WebSocket 握手失败

			# 立即刷新响应，确保 WebSocket/SSE 不被缓冲
			flush_interval -1
		}
	}

	# 日志
	log {
		output stdout
		format console
	}

	# 压缩（排除 WebSocket 连接，避免干扰 HMR 握手）
	@notWebSocket not header Connection *pgrade*
	encode @notWebSocket gzip zstd
}
