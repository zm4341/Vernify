# Lattice 全栈配置
# 复制此文件为 .env 并填写实际值

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-super-secret-password
POSTGRES_DB=lattice
DATABASE_URL=postgresql://postgres:your-super-secret-password@db:5432/lattice

# ===========================================
# Supabase 配置
# ===========================================
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# 注册/登录验证码邮件（GoTrue 发信，不配置则收不到真实邮件）
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=
GOTRUE_SMTP_SENDER_NAME=Lattice

# ===========================================
# Redis 配置
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# LLM 配置 (使用 LiteLLM 统一管理)
# ===========================================
# 文档: https://docs.litellm.ai/docs/providers
#
# 默认模型 (LiteLLM 格式: provider/model-name)
# 支持的提供商: gemini/, openai/, anthropic/, azure/, openrouter/
LLM_MODEL=gemini/gemini-3-pro-preview

# 回退模型列表 (逗号分隔，按优先级排列；OpenRouter 格式: openrouter/provider/model)
LLM_FALLBACK_MODELS=openrouter/openai/gpt-5.2,openrouter/openai/gpt-5.mini

# RAG：Embedding 模型（用于 pgvector 向量化）
EMBEDDING_MODEL=gemini/gemini-embedding-001
# RAG：Reranker 模型（检索结果重排序）
RERANKER_MODEL=gemini/gemini-2.5-flash-lite

# -------------------------------------------
# Google Gemini (AI Studio)
# 获取 API Key: https://aistudio.google.com/apikey
# -------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# -------------------------------------------
# OpenAI
# -------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# -------------------------------------------
# Anthropic
# -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# -------------------------------------------
# OpenRouter (统一 API 访问 100+ 模型)
# 格式: openrouter/provider/model，如 openrouter/openai/gpt-5.2
# 使用 openrouter/ 模型时需配置本 Key；无需 base_url，LiteLLM 自动路由
# 获取 API Key: https://openrouter.ai/keys
# -------------------------------------------
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# -------------------------------------------
# Azure OpenAI
# -------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# ===========================================
# 前端配置
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
# 浏览器端 Supabase URL，需与访问页同源，否则登录态和 Cookie 会失效
# 用 localhost 访问则填 http://localhost:38080，用 127.0.0.1 则填 http://127.0.0.1:38080
NEXT_PUBLIC_SUPABASE_URL=http://localhost:38080
# 必须与 SUPABASE_ANON_KEY 一致，否则登录会报 Failed to fetch 或 401
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Docker 环境下服务端访问 Supabase 的内部 URL（开发: http://caddy:38080，生产: http://supabase-kong:8000）
# SUPABASE_SERVER_URL=http://caddy:38080

# ===========================================
# 后端配置
# ===========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-for-signing

# Next 请求后端 AI 服务（批改、流式对话）。Docker: http://backend:8000，本地: http://localhost:8000
AI_SERVICE_URL=http://backend:8000
# 流式对话使用的模型（LiteLLM 格式，与后端 LLM_MODEL 可一致或不同）
AI_CHAT_MODEL=gemini/gemini-3-pro-preview

# ===========================================
# Celery 配置
# ===========================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===========================================
# Caddy 配置
# ===========================================
# 生产环境使用域名，如 example.com
SITE_ADDRESS=localhost
# API 域名，如 api.example.com
API_ADDRESS=api.localhost

# ===========================================
# Auth 回调（Lattice 在 Docker 中运行）
# ===========================================
# GoTrue 登录/注册回调 URL，需与浏览器访问地址一致
# Docker 下经 Caddy 访问，使用 38080
# SITE_URL=http://127.0.0.1:38080
